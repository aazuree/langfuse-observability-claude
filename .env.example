# Langfuse Self-Hosted Configuration
# Copy to .env and run: ./setup.sh (generates secrets automatically)
# Or fill in manually — all CHANGEME values must be replaced.

# === Langfuse Core ===
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGEME_64_char_hex
ENCRYPTION_KEY=CHANGEME_64_char_hex
SALT=CHANGEME_32_char_hex

# === PostgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=postgres
DATABASE_URL=postgresql://postgres:CHANGEME@postgres:5432/postgres

# === ClickHouse ===
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=CHANGEME

# === Redis ===
REDIS_AUTH=CHANGEME

# === MinIO (S3-compatible storage) ===
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=CHANGEME
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=CHANGEME
LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=CHANGEME

# === Initial Setup (auto-creates org, project, and user on first boot) ===
LANGFUSE_INIT_ORG_ID=my-org
LANGFUSE_INIT_ORG_NAME=MyOrg
LANGFUSE_INIT_PROJECT_ID=claude-code
LANGFUSE_INIT_PROJECT_NAME=ClaudeCode
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=CHANGEME_generated_by_setup
LANGFUSE_INIT_PROJECT_SECRET_KEY=CHANGEME_generated_by_setup
LANGFUSE_INIT_USER_EMAIL=CHANGEME
LANGFUSE_INIT_USER_NAME=CHANGEME
LANGFUSE_INIT_USER_PASSWORD=CHANGEME_min_12_chars
